---
import AppShell from "../layouts/AppShell.astro";
import LandingPageStandard from "../components/landing/LandingPageStandard.astro";
import type { LandingPageContent } from "../lib/landing";
import { buildRootRedirect } from "../lib/redirects";

const rootAppUrl = Astro.locals.rootAppUrl ?? "https://ansiversa.com";
const appUrl = new URL("/app", Astro.url).toString();
const startHref = Astro.locals.isAuthenticated ? "/app" : buildRootRedirect(rootAppUrl, "/login", appUrl);

const landingContent: LandingPageContent = {
  categoryLabel: "Writing Workspace",
  appLabel: "Authenticated DB-backed workspace",
  title: "Keep blog drafts in one personal workspace instead of losing strong writing between revisions.",
  subtitle:
    "Create blog post records, refine title, summary, body, and notes over time, favorite the strongest drafts, archive older work, and return when you need a better starting point.",
  heroBullets: [
    "Store title, slug, category, tags, summary, body, status, and notes in one protected record",
    "Use search and simple filters to find active, archived, or favorite drafts faster",
    "Open a full detail page whenever the article needs focused editing instead of a short list preview",
  ],
  primaryCta: {
    label: Astro.locals.isAuthenticated ? "Open Workspace" : "Sign in to Open",
    href: startHref,
  },
  secondaryCta: {
    label: "See Workflow",
    href: "#workflow",
    variant: "ghost",
  },
  heroNote:
    "Current V1 is a manual drafting workspace. It does not write posts with AI, publish them to a website, or score SEO performance.",
  heroPanel: {
    eyebrow: "Draft flow",
    title: "Capture → Refine → Revisit",
    steps: [
      "1. Save the post title and content in a protected record",
      "2. Edit the draft over time, favorite strong posts, and archive older ones",
      "3. Return later when you need a reliable starting point",
    ],
    meta: [
      { value: "DB", label: "Persistence" },
      { value: "Per-user", label: "Ownership" },
    ],
  },
  features: {
    title: "What Blog Writer gives you in V1",
    lead:
      "The value is in keeping blog drafting structured and reusable, not in pretending to be a publishing CMS, AI writer, or SEO analytics product.",
    items: [
      {
        title: "Structured draft records",
        description:
          "Keep title, slug, category, tags, summary, article body, status, and notes together in one record.",
      },
      {
        title: "Searchable writing library",
        description:
          "Search title, summary, content, tags, and notes so older writing is easier to reopen and reuse.",
      },
      {
        title: "Favorite and archive states",
        description:
          "Mark strong drafts worth revisiting and move inactive writing out of the active view without deleting it.",
      },
      {
        title: "Full detail editing",
        description:
          "Open a dedicated detail route whenever a post needs full-body editing instead of just workspace scanning.",
      },
    ],
  },
  pillars: {
    title: "Why this works better than scattered writing docs",
    lead:
      "The product stays intentionally narrow: one personal draft library that helps keep writing organized, editable, and easy to revisit without turning into a publishing platform.",
    items: [
      {
        title: "Truthful product boundary",
        description:
          "This is a manual blog drafting and organization workspace, not an AI writer, CMS, SEO platform, or team editorial tool.",
      },
      {
        title: "Protected personal ownership",
        description:
          "Protected routes and owner-scoped records keep each user’s writing library separate and safe to revise over time.",
      },
      {
        title: "Drafts worth reusing",
        description:
          "Favorites, archive controls, and search make it easier to return to older posts when a new article needs a better base.",
      },
      {
        title: "Safe state changes",
        description:
          "Create, update, favorite, archive, and restore flows stay predictable without hard-delete risk in V1.",
      },
    ],
  },
  workflow: {
    eyebrow: "How it works",
    title: "Build a blog draft library you can keep refining",
    lead:
      "The workflow is built around capturing useful writing once, improving it when needed, and keeping the workspace clear over time.",
    steps: [
      {
        title: "Sign in and create a draft",
        description:
          "Open the protected workspace and save the title, content, and context fields for the post you want to keep working on.",
      },
      {
        title: "Refine the article in detail",
        description:
          "Use the detail page to revise summary, content, tags, notes, and status whenever the draft needs another pass.",
      },
      {
        title: "Favorite, archive, and reopen later",
        description:
          "Keep strong drafts easy to find and move older work out of the default view without losing it.",
      },
    ],
  },
  showcase: {
    eyebrow: "Current product shape",
    title: "Built for structured draft storage and revision, not website publishing",
    description:
      "The landing stays aligned to the V1 scope: Blog Writer is a protected personal workspace for saving, editing, favoriting, archiving, and revisiting blog post drafts.",
    bullets: [
      "Good fit for solo writers, founders, marketers, and creators preparing content before publishing elsewhere",
      "Centered on manual drafting, safe organization, and dependable retrieval",
    ],
    calloutLabel: "Freeze truth",
    calloutValue: "Manual drafting workspace",
  },
  finalCta: {
    title: "Start building a draft library you can actually revisit",
    description:
      "Open the workspace, save the writing worth keeping, and make the next article easier to start from stronger material.",
    primaryCta: {
      label: Astro.locals.isAuthenticated ? "Open Workspace" : "Sign in to Open",
      href: startHref,
    },
    secondaryCta: {
      label: "Review Features",
      href: "#features",
      variant: "ghost",
    },
  },
};
---

<AppShell title="Blog Writer — Ansiversa" description="A protected personal workspace for drafting and organizing blog post records.">
  <LandingPageStandard content={landingContent} />
</AppShell>
